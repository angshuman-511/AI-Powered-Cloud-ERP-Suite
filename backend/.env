# Server
PORT=5000
NODE_ENV=development

# JWT Secrets
JWT_ACCESS_SECRET=amdox-erp-dev-access-secret-2026
JWT_REFRESH_SECRET=amdox-erp-dev-refresh-secret-2026
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Twilio (mock in dev)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Database
DB_PATH=./database/amdox_erp.db
