# Server
PORT=5000
NODE_ENV=development

# JWT Secrets (generate strong random strings for production)
JWT_ACCESS_SECRET=amdox-erp-access-secret-change-in-production
JWT_REFRESH_SECRET=amdox-erp-refresh-secret-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Google OAuth (get from https://console.cloud.google.com)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Twilio (for phone OTP in production)
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Database
DB_PATH=./database/amdox_erp.db
